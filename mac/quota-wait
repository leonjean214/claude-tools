#!/usr/bin/env python3
"""
quota-wait — 等到 Claude 额度可用再退出

用法：
  quota-wait              # 额度满则等到重置，否则立即退出
  quota-wait --status     # 只打印当前状态，不等待
  quota-wait --threshold 90  # 超过 90% 就等（默认 100）

退出码：
  0 = 额度可用
  1 = 无法获取 token 或 API 失败
"""
import subprocess, json, urllib.request, datetime, sys, time, argparse

def get_token():
    raw = subprocess.check_output(
        ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
        text=True, stderr=subprocess.DEVNULL
    ).strip()
    return json.loads(raw)["claudeAiOauth"]["accessToken"]

def fetch_usage(token):
    req = urllib.request.Request(
        "https://api.anthropic.com/api/oauth/usage",
        headers={"Authorization": f"Bearer {token}"}
    )
    return json.load(urllib.request.urlopen(req, timeout=10))

def parse_usage(data):
    results = []
    for key in ("five_hour", "seven_day"):
        w = data.get(key) or {}
        u = w.get("utilization") or 0
        r = w.get("resets_at") or ""
        if r:
            dt = datetime.datetime.fromisoformat(r).astimezone()
            results.append((key, float(u), dt))
    return results  # [(name, utilization%, reset_dt), ...]

def fmt_dt(dt):
    now = datetime.datetime.now().astimezone()
    mins = int((dt - now).total_seconds() / 60)
    t = dt.strftime("%H:%M")
    if mins <= 0: return f"{t}(已过)"
    if mins < 60: return f"{t}({mins}m后)"
    return f"{t}({mins//60}h{mins%60:02d}m后)"

def bar(u):
    f = min(int(u / 100 * 20), 20)
    return "█" * f + "░" * (20 - f)

def print_status(windows):
    now = datetime.datetime.now().strftime("%H:%M:%S")
    max_u = max(u for _, u, _ in windows) if windows else 0
    overall = "🚫" if max_u >= 100 else "⚠️" if max_u >= 75 else "✅"
    print(f"=== Claude 额度 {overall}  [{now}] ===")
    for name, u, reset_dt in windows:
        label = "5h" if "five" in name else "7d"
        print(f"{label}  [{bar(u)}] {u:.0f}%  reset {fmt_dt(reset_dt)}")

def main():
    parser = argparse.ArgumentParser(description="等到 Claude 额度可用")
    parser.add_argument("--status", action="store_true", help="只打印状态，不等待")
    parser.add_argument("--threshold", type=float, default=100, help="触发等待的用量阈值（默认 100）")
    args = parser.parse_args()

    try:
        token = get_token()
    except Exception as e:
        print(f"❌ 获取 token 失败: {e}", file=sys.stderr)
        sys.exit(1)

    while True:
        try:
            data = fetch_usage(token)
            windows = parse_usage(data)
        except Exception as e:
            print(f"❌ API 失败: {e}", file=sys.stderr)
            sys.exit(1)

        print_status(windows)

        if args.status:
            sys.exit(0)

        # 找出超过阈值的窗口，取最早重置的那个
        blocked = [(u, dt) for _, u, dt in windows if u >= args.threshold]
        if not blocked:
            print("✅ 额度可用，继续。")
            sys.exit(0)

        # 等到最早的重置时间 + 1min
        earliest_reset = min(dt for _, dt in blocked)
        wait_until = earliest_reset + datetime.timedelta(minutes=1)
        now = datetime.datetime.now().astimezone()
        wait_secs = (wait_until - now).total_seconds()

        if wait_secs <= 0:
            print("✅ 重置时间已过，继续。")
            sys.exit(0)

        wake_str = wait_until.strftime("%H:%M:%S")
        print(f"⏳ 额度 {max(u for u,_ in blocked):.0f}%，等到 {wake_str} 再继续… (还有 {int(wait_secs//60)}m{int(wait_secs%60):02d}s)")

        # 每 60s 打印一次倒计时，直到重置时间
        check_interval = min(60, wait_secs)
        time.sleep(check_interval)
        # 重置后重新查一次确认
        print()

if __name__ == "__main__":
    main()
