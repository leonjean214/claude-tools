#!/usr/bin/env python3
"""
quota-wait — 检测 Claude 额度，可用时放行或触发续命

用法：
  quota-wait              # 额度满则阻塞等到重置，否则立即退出
  quota-wait --status     # 只打印当前状态，不等待
  quota-wait --watch      # 后台守护：持续监控，满了等重置后自动触发 claude-resume.sh
  quota-wait --threshold 90  # 超过 90% 就等（默认 100）

退出码：0=可用  1=失败
"""
import subprocess, json, urllib.request, datetime, sys, time, argparse, os, signal

LOCKFILE = "/tmp/quota-watch.lock"
RESUME_SCRIPT = os.path.expanduser("~/bin/claude-resume.sh")
LOG = os.path.expanduser("~/quota-watch.log")

def get_token():
    raw = subprocess.check_output(
        ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
        text=True, stderr=subprocess.DEVNULL
    ).strip()
    return json.loads(raw)["claudeAiOauth"]["accessToken"]

def fetch_usage(token):
    req = urllib.request.Request(
        "https://api.anthropic.com/api/oauth/usage",
        headers={"Authorization": f"Bearer {token}"}
    )
    return json.load(urllib.request.urlopen(req, timeout=10))

def parse_windows(data):
    out = []
    for key in ("five_hour", "seven_day"):
        w = data.get(key) or {}
        u = float(w.get("utilization") or 0)
        r = w.get("resets_at") or ""
        if r:
            dt = datetime.datetime.fromisoformat(r).astimezone()
            out.append((key, u, dt))
    return out

def fmt_dt(dt):
    now = datetime.datetime.now().astimezone()
    mins = int((dt - now).total_seconds() / 60)
    t = dt.strftime("%H:%M")
    if mins <= 0: return f"{t}(已过)"
    if mins < 60: return f"{t}({mins}m后)"
    return f"{t}({mins//60}h{mins%60:02d}m后)"

def bar(u):
    f = min(int(u / 100 * 20), 20)
    return "█" * f + "░" * (20 - f)

def print_status(windows, file=sys.stdout):
    now = datetime.datetime.now().strftime("%H:%M:%S")
    max_u = max((u for _, u, _ in windows), default=0)
    icon = "🚫" if max_u >= 100 else "⚠️" if max_u >= 75 else "✅"
    print(f"=== Claude 额度 {icon}  [{now}] ===", file=file)
    for name, u, reset_dt in windows:
        label = "5h" if "five" in name else "7d"
        print(f"{label}  [{bar(u)}] {u:.0f}%  reset {fmt_dt(reset_dt)}", file=file)

def watch_mode(threshold):
    """后台守护：持续监控额度，满了等重置后触发 claude-resume.sh"""

    # 防多实例：open(..., 'x') 是原子操作，彻底消除竞态
    while True:
        try:
            with open(LOCKFILE, 'x') as f:
                f.write(str(os.getpid()))
            break  # 成功拿到锁
        except FileExistsError:
            try:
                pid = int(open(LOCKFILE).read().strip())
                os.kill(pid, 0)
                print(f"quota-watch 已在运行 (PID {pid})，退出。", file=sys.stderr)
                sys.exit(0)
            except (ProcessLookupError, ValueError):
                try: os.remove(LOCKFILE)
                except FileNotFoundError: pass  # 另一进程已删，重试

    def cleanup(sig=None, frame=None):
        try: os.remove(LOCKFILE)
        except: pass
        sys.exit(0)
    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGINT, cleanup)

    def log(msg):
        ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        line = f"[{ts}] {msg}"
        with open(LOG, "a") as f:
            f.write(line + "\n")
        if sys.stdout.isatty():
            print(line, flush=True)

    # /api/oauth/usage 是纯状态查询，不走 Messages API，不消耗 Claude 额度
    POLL = 300  # 5min 查一次
    token = get_token()
    log(f"quota-watch 启动 (PID {os.getpid()}, threshold={threshold}%, poll={POLL}s)")
    fired = False

    try:
        while not fired:
            try:
                data = fetch_usage(token)
                windows = parse_windows(data)
            except urllib.error.HTTPError as e:
                if e.code == 401:
                    log("Token 过期，重新获取…")
                    try:
                        token = get_token()
                        log("Token 已刷新，立即重试")
                        time.sleep(5)
                    except Exception as te:
                        log(f"刷新 token 失败: {te}，{POLL}s 后重试")
                        time.sleep(POLL)
                else:
                    log(f"API 失败: {e}，{POLL}s 后重试")
                    time.sleep(POLL)
                continue
            except Exception as e:
                log(f"API 失败: {e}，{POLL}s 后重试")
                time.sleep(POLL)
                continue

            max_u = max((u for _, u, _ in windows), default=0)
            log(f"额度: " + "  ".join(
                f"{'5h' if 'five' in n else '7d'}={u:.0f}%" for n, u, _ in windows
            ))

            blocked = [(u, dt) for _, u, dt in windows if u >= threshold]
            if not blocked:
                time.sleep(POLL)
                continue

            # 额度满，等到最早重置点 +1min
            earliest = min(dt for _, dt in blocked)
            wait_until = earliest + datetime.timedelta(minutes=1)
            now = datetime.datetime.now().astimezone()
            wait_secs = (wait_until - now).total_seconds()

            if wait_secs > 0:
                log(f"额度 {max_u:.0f}%，等到 {wait_until.strftime('%H:%M:%S')} 触发续命 ({int(wait_secs//60)}m后)")
                while True:
                    now = datetime.datetime.now().astimezone()
                    remaining = (wait_until - now).total_seconds()
                    if remaining <= 0:
                        break
                    time.sleep(min(POLL, remaining))
                    remaining = (wait_until - now).total_seconds()
                    if remaining > 0:
                        log(f"等待中… 还有 {int(remaining//60)}m{int(remaining%60):02d}s")

            # 如果 Claude Code 交互进程正在运行，让 UI 的 stop-and-wait 自己处理
            try:
                ps = subprocess.run(["pgrep", "-lf", "claude"], capture_output=True, text=True)
                interactive_running = any(
                    ".local/bin/claude" in line
                    and " -p " not in line
                    and "--print" not in line
                    and "quota-wait" not in line
                    and "claude-resume" not in line
                    for line in ps.stdout.splitlines()
                )
            except Exception:
                interactive_running = False

            if interactive_running:
                log("检测到 Claude Code 交互进程运行中，跳过自动触发（UI stop-and-wait 会处理）。quota-watch 退出。")
                fired = True
                continue

            log(f"重置时间到，触发 claude-resume.sh")
            try:
                subprocess.Popen(
                    ["/bin/bash", RESUME_SCRIPT],
                    stdout=open(os.path.expanduser("~/claude-resume.log"), "a"),
                    stderr=subprocess.STDOUT,
                    start_new_session=True
                )
                log("claude-resume.sh 已启动，quota-watch 退出。")
            except Exception as e:
                log(f"启动 claude-resume.sh 失败: {e}")
            fired = True
    finally:
        cleanup()

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--status", action="store_true")
    parser.add_argument("--watch", action="store_true")
    parser.add_argument("--threshold", type=float, default=100)
    args = parser.parse_args()

    if args.watch:
        watch_mode(args.threshold)
        return

    try:
        token = get_token()
    except Exception as e:
        print(f"❌ 获取 token 失败: {e}", file=sys.stderr)
        sys.exit(1)

    while True:
        try:
            data = fetch_usage(token)
            windows = parse_windows(data)
        except Exception as e:
            print(f"❌ API 失败: {e}", file=sys.stderr)
            sys.exit(1)

        print_status(windows)
        if args.status:
            sys.exit(0)

        blocked = [(u, dt) for _, u, dt in windows if u >= args.threshold]
        if not blocked:
            print("✅ 额度可用，继续。")
            sys.exit(0)

        earliest = min(dt for _, dt in blocked)
        wait_until = earliest + datetime.timedelta(minutes=1)
        now = datetime.datetime.now().astimezone()
        wait_secs = (wait_until - now).total_seconds()

        if wait_secs <= 0:
            print("✅ 重置时间已过，继续。")
            sys.exit(0)

        max_u = max(u for u, _ in blocked)
        print(f"⏳ 额度 {max_u:.0f}%，等到 {wait_until.strftime('%H:%M:%S')} ({int(wait_secs//60)}m{int(wait_secs%60):02d}s)")
        time.sleep(min(60, wait_secs))
        print()

if __name__ == "__main__":
    main()
